{
  "manifest_version": 3,
  "name": "Pressure Cooker - PDF Multi-Resolution Capture",
  "version": "1.0.2",
  "description": "Captures multi-resolution images from PDFs and packages them into a ZIP file",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "downloads",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pressure Cooker - PDF Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon-16.svg",
    "48": "images/icon-48.svg",
    "128": "images/icon-128.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://* file://*"
  }
}
